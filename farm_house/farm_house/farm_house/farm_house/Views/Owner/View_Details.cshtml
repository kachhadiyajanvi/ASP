
@{
    ViewData["Title"] = "View_Propertys";
    Layout = "~/Views/Shared/OwnerLayout.cshtml";
}


<link href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">

<style>
    .farm-image {
    margin: 5px;
    }
</style>


<div class="content-wrapper">
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>View Properties</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="#">Home</a></li>
                        <li class="breadcrumb-item active">View Properties</li>
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <!-- Main content -->
    <section class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <form class="search-form form-inline w-100" method="get">
                                <input type="text" name="search" class="form-control flex-grow-1 mr-2" placeholder="Search by name..." value="">
                                <input type="submit" name="submit" value="Search" class="btn btn-dark">
                            </form>
                        </div>
                        <!-- /.card-header -->
                        <div class="card-body">
                            <div class="property-section">
                                <div class="property-part  w-100">
                                    <table class="table table-bordered">
                                        <tbody>
                                            @foreach (System.Data.DataRow dr in ViewBag.data.Rows)
                                            {
                                                <tr>
                                                    <th>Id</th>
                                                    <td>@dr["id"].ToString()</td>
                                                </tr>
                                                <tr>
                                                    <th>Name</th>
                                                    <td>@dr["name"].ToString()</td>
                                                </tr>
                                                <tr>
                                                    <th>Category</th>
                                                    <td>@dr["category"].ToString()</td>
                                                </tr>
                                                <tr>
                                                    <th>City</th>
                                                    <td>@dr["city"].ToString()</td>
                                                </tr>
                                                <tr>
                                                    <th>Rate</th>
                                                    <td>@dr["rate"].ToString()</td>
                                                </tr>
                                                <tr>
                                                    <th>Facilities</th>
                                                    <td>@dr["facilities"].ToString()</td>
                                                </tr>
                                                <tr>
                                                    <th>Bedrooms</th>
                                                    <td>@dr["bedrooms"].ToString()</td>
                                                </tr>
                                                <tr>
                                                    <th>Bathrooms</th>
                                                    <td>@dr["bathrooms"].ToString()</td>
                                                </tr>
                                                <tr>
                                                    <th>Location Link</th>
                                                    <td>
                                                        <a href="" target="_blank" rel="noopener noreferrer">
                                                            @dr["location_link"].ToString()
                                                        </a>
                                                    </td>
                                                </tr>
                                                <tr>
                                                    <th>Address</th>
                                                    <td>@dr["address"].ToString()</td>
                                                </tr>
                                                <tr>
                                                    <th>Banner Image</th>
                                                    <td><a href="~/image/@dr["id"].ToString()"> <img src="~/image/@dr["image"].ToString()" width="100px"></a></td>
                                                </tr>
                                                @* <tr>
                                                    <th>Farm Images</th>
                                                    <td>
                                                    </td>
                                                </tr> *@
                                                <tr>
                                                    <th>Rules</th>
                                                    <td>@dr["rules"].ToString()</td>
                                                </tr>
                                                <tr>
                                                    <th>Space(sq ft)</th>
                                                    <td>@dr["space"].ToString()</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
