
@{
    ViewData["Title"] = "Update_Admin";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}


<link href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">

<div class="content-wrapper">
    <section class="content-header">
        <div class="container-fluid">
            <div class="row mb-2">
                <div class="col-sm-6">
                    <h1>Add Admin</h1>
                </div>
                <div class="col-sm-6">
                    <ol class="breadcrumb float-sm-right">
                        <li class="breadcrumb-item"><a href="#">Home</a></li>
                        <li class="breadcrumb-item active">Add Admin</li>
                    </ol>
                </div>
            </div>
        </div>
    </section>

    <section class="content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-6">
                    <div class="card card-dark">
                        <div class="card-header"></div>
                        @foreach (System.Data.DataRow dr in ViewBag.data.Rows)
                        {
                            <form method="post" enctype="multipart/form-data" id="frm">
                                <div class="card-body">
                                    <div class="form-group">
                                        <label for="username">Name</label>
                                        <input type="text" name="name" class="form-control" id="username" placeholder="Enter name" value="@dr["name"].ToString()">
                                        <span style="color: red; display: none;">Enter Username....</span>
                                    </div>
                                    <div class="form-group">
                                        <label for="email">Email address</label>
                                        <input type="email" name="email" class="form-control" id="email" placeholder="Enter email" value="@dr["email"].ToString()">
                                        <span style="color: red; display: none;">Enter Email Address....</span>
                                    </div>
                                    <div class="form-group" id="passwordd">
                                        <label for="password">Password</label>
                                        <input type="password" name="password" class="form-control" id="password" placeholder="Password" value="@dr["password"].ToString()">
                                        <span style="color: red; display: none;">Enter Password....</span>
                                    </div>
                                    <div class="form-group">
                                        <label for="exampleInputFile">Image</label>
                                        <div class="input-group">
                                            <div class="custom-file">
                                                <label class="custom-file-label">Choose Image</label>
                                                <input type="file" name="image" class="custom-file-input">
                                            </div>
                                        </div>
                                    </div>
                                    <span style="color: red; display: none;" id="image_error">Enter Image...!</span>
                                </div>
                                <div class="card-footer">
                                    <button type="submit" name="submit" class="btn btn-dark">Submit</button>
                                </div>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
