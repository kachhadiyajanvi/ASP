
@{
    ViewData["Title"] = "About";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">

<!-- Tempusdominus Bootstrap 4 -->
<link rel="stylesheet" href="~/plugins/tempusdominus-bootstrap-4/css/tempusdominus-bootstrap-4.min.css">
<!-- iCheck -->
<link rel="stylesheet" href="~/plugins/icheck-bootstrap/icheck-bootstrap.min.css">

<style>
    .section-padding {
    padding: 60px 0;
    }

    .section-title {
    text-align: center;
    margin-bottom: 40px;
    }

    .col-md-4:hover img {
    transform: scale(1.1);
    transition: transform 0.3s ease;
    }

    .col-md-4:hover h4 {
    color: #f35525;
    transition: color 0.3s ease;
    }

    .team-img {
    width: 150px;
    height: 150px;
    object-fit: cover;
    border-radius: 50%;
    margin: 0 auto 15px;
    display: block;
    }

    .team-card-body {
    padding: 10px;
    }

    .social-links {
    list-style: none;
    padding: 0;
    margin: 15px 0 0;
    }

    .social-links li {
    display: inline-block;
    margin: 0 10px;
    }

    .social-links li a {
    color: #333;
    font-size: 20px;
    transition: color 0.3s ease;
    }

    .social-links li a:hover {
    color: #f35525;
    }

    .box-shadow {
    box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.15);
    padding: 20px 45px;
    border-radius: 12px;
    background-color: #fff;
    margin-bottom: 20px;
    transition: transform 0.2s;
    }

    .box-shadow:hover {
    transform: translateY(-5px);
    }

    .icon-rounded {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background-color: #f0f0f0;
    box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.2);
    margin-bottom: 15px;
    }

    .icon-rounded i {
    color: #333;
    font-size: 2rem;
    }

    .mx-auto {
    margin-left: auto;
    margin-right: auto;
    }

    h4 {
    font-weight: 600;
    }

    p {
    color: #666;
    }

    .img-fluid {
    border-radius: 15px;
    box-shadow: 0px 8px 20px rgba(0, 0, 0, 0.15);
    }

    .p-4 {
    padding: 20px 30px;
    }

    .display-5 {
    font-size: 2.5rem;
    }

    .font-weight-bold {
    font-weight: 700;
    }

    .lead {
    font-size: 1.125rem;
    color: #555;
    }

    .section-title h2 {
    font-size: 2.5rem;
    margin-bottom: 20px;
    }

    .section-title hr {
    border: 0;
    height: 2px;
    background-color: #007bff;
    }

    .history-content {
    background-color: #f8f9fa;
    border-radius: 15px;
    padding: 20px 30px;
    box-shadow: 0px 4px 15px rgba(0, 0, 0, 0.1);
    font-size: 1.125rem;
    line-height: 1.8;
    }

    .history-content strong {
    font-weight: 600;
    }

