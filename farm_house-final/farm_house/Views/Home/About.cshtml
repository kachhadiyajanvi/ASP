<div class="page-heading header-text">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <span class="breadcrumb"><a href="#">Home</a> / About Us</span>
                <h3>About Us</h3>
            </div>
        </div>
    </div>
</div>

<section class="section-padding bg-light">
    <div class="container">
        <div class="section-title">
            <h2>What We Offer</h2>
        </div>
        <div class="container">
            <div class="row justify-content-center">
                @foreach (System.Data.DataRow dr in ViewBag.ds2.Rows)
                {
                    <div class="col-md-3 text-center box-shadow p-4 me-5">
                        <div class="icon-rounded mx-auto mb-3">
                            <p class="text-center pt-4 fs-1"><a href="#"><i class="@dr["icon"].ToString()"></i></a></p>
                        </div>
                        <h4 class="m-3">@dr["title"].ToString()</h4>
                        <p>@dr["description"].ToString()</p>
                    </div>
                }
            </div>
        </div>

    </div>
</section>

<section class="section-padding bg-light">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-6">
                <img src="~/image/banner-01.jpg" alt="Farmhouse" class="img-fluid rounded shadow-lg">
            </div>
            <div class="col-md-6">
                <div class="p-4">
                    <h2 class="display-5 font-weight-bold mb-3">Welcome to Our Farmhouse Booking Website</h2>
                    <p class="lead">Our farmhouses offer a unique blend of comfort, luxury, and nature. Whether you're looking to escape the hustle and bustle of city life or plan a special event, our farmhouses provide the perfect setting for relaxation and enjoyment.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-padding">
    <div class="container">
        <div class="section-title text-center mb-5">
            <h2 class="display-4 font-weight-bold">Our History</h2>
            <hr class="w-25 mx-auto">
        </div>
        <div class="row">
            <div class="col-md-12">
                <div class="history-content p-4 bg-light rounded shadow-sm">
                    <p class="lead">Established in <strong>2024</strong>, our farmhouses have been a preferred destination for families, friends, and corporate retreats. Our journey began with a simple idea: to create a place where people can connect with nature, unwind, and create lasting memories. Over the years, we have grown and evolved, continually striving to provide exceptional experiences and unparalleled hospitality.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="section-padding bg-light">
    <div class="container"> 
        <div class="section-title text-center">
            <h2>Meet Our Team</h2>
            <p class="fs-6">Our dedicated team of professionals is here to assist you. Get to know the people behind our success.</p>
        </div>
        <div class="row">
             <section class="team"> 
                <div class="container">
                    <div class="section-heading">
                        <div class="section-dec"></div>
                    </div> 
                    <div class="row">
                        @foreach (System.Data.DataRow dr in ViewBag.ds.Rows)
                        {
                            <div class="col-md-4">
                                <div class="team-card text-center shadow-sm rounded">
                                    <img src="~/image/@dr["image"].ToString()" alt="John Doe" class="team-img rounded-top" />
                                    <div class="team-card-body p-4">
                                        <h4 class="mb-2 font-weight-bold">@dr["name"].ToString()</h4>
                                        <p class="text-muted mb-3">@dr["position"].ToString()</p>
                                        <p>@dr["descriptions"].ToString()</p>
                                        <ul class="social-links list-inline mt-3">
                                            <li class="list-inline-item"><a href="#"><i class="fab fa-facebook"></i></a></li>
                                            <li class="list-inline-item"><a href="#"><i class="fab fa-twitter"></i></a></li>
                                            <li class="list-inline-item"><a href="#"><i class="fab fa-linkedin"></i></a></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div> 
           </section> 
        </div>
    </div>
</section>


<!-- Resolve conflict in jQuery UI tooltip with Bootstrap tooltip -->
<script>
    $.widget.bridge('uibutton', $.ui.button)
</script>
<!-- Bootstrap 4 -->
<script src="~/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
